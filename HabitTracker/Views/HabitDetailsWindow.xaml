<Window x:Class="HabitTracker.Views.HabitDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szokás Részletei" Height="450" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="Szokás neve:"/>
            <TextBox x:Name="NameTextBox" Margin="0,5,0,15"/>

            <TextBlock Text="Típus:"/>
            <ComboBox x:Name="TypeComboBox" Margin="0,5,0,25">
                <ComboBoxItem Content="Rossz szokás (Leszokás)"/>
                <ComboBoxItem Content="Jó szokás (Rászokás)"/>
            </ComboBox>

            <Button Content="Módosítások mentése" Click="SaveHabit_Click" Height="35" Margin="0,0,0,20"/>

            <TextBlock Text="Statisztika és Predikció" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="StatsTextBlock" TextWrapping="Wrap" Text="Adatok betöltése..."/>
        </StackPanel>

        <DockPanel Grid.Column="1">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="NewLogNoteTextBox" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                <Button Content="Új bejegyzés" Click="AddLog_Click" Width="100" Height="25"/>
            </StackPanel>

            <Button DockPanel.Dock="Bottom" Content="Kiválasztott bejegyzés törlése" Click="DeleteLog_Click" Height="30" Margin="0,10,0,0"/>

            <ListBox x:Name="LogsList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy.MM.dd HH:mm}'}" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding Note}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>