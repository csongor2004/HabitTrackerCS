<Page x:Class="HabitTracker.Views.HabitAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="{DynamicResource CardBg}">
            <Button Content="&lt; Vissza a Kezelőpulthoz" Click="Back_Click" Width="180" Margin="15,0" Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Foreground="{DynamicResource PrimaryText}"/>
            <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ChartTitleText" Grid.Row="0" Text="Két alkalom között eltelt idő (Trend)" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChartControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="10,0" VerticalAlignment="Bottom" ToolTip="{Binding ToolTipText}">
                                        <TextBlock Text="{Binding DisplayHours}" TextAlignment="Center" Margin="0,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                                        <Border Background="#42A5F5" Width="50" Height="{Binding PixelHeight}" CornerRadius="4,4,0,0"/>
                                        <TextBlock Text="{Binding EndDate}" TextAlignment="Center" Margin="0,5,0,0" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🎯 Viselkedési Profil" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1976D2"/>

                        <TextBlock Text="Legaktívabb nap:" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock x:Name="FreqDayText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock Text="Kritikus napszak:" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock x:Name="FreqTimeText" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🤖 AI Elemzés és Trend" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="DeepAnalysisText" TextWrapping="Wrap" FontSize="15" LineHeight="24"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>