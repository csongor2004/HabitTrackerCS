<Page x:Class="HabitTracker.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Főmenü">
    <Grid Background="#FAFAFA">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Habit Tracker" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Rossz szokások (Leszokás)" Click="BadHabits_Click" Width="300" Height="60" Margin="10" Background="#E53935" Foreground="White" FontSize="18"/>
            <Button Content="Jó szokások (Rászokás)" Click="GoodHabits_Click" Width="300" Height="60" Margin="10" Background="#43A047" Foreground="White" FontSize="18"/>
        </StackPanel>
    </Grid>
</Page>