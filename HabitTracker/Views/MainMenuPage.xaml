<Page x:Class="HabitTracker.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Főmenü">
    <Grid Background="#FAFAFA">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Habit Tracker" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Rossz szokások (Leszokás)" Click="BadHabits_Click" Width="250" Height="50" Margin="10" Background="#FFCDD2" FontSize="16"/>
            <Button Content="Jó szokások (Rászokás)" Click="GoodHabits_Click" Width="250" Height="50" Margin="10" Background="#C8E6C9" FontSize="16"/>
        </StackPanel>
    </Grid>
</Page>