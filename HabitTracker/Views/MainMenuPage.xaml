<Page x:Class="HabitTracker.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Főmenü"
      Background="Transparent">
    <Grid Background="Transparent">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Habit Tracker" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,30" Width="450" Visibility="Collapsed" x:Name="AiDashboardPanel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🤖 Napi AI Összegzés" FontSize="18" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,10"/>
                    <TextBlock x:Name="AiSummaryText" TextWrapping="Wrap" FontSize="15" LineHeight="24" Foreground="{DynamicResource SecondaryText}"/>
                </StackPanel>
            </Border>

            <Button Content="Rossz szokások (Leszokás)" Click="BadHabits_Click" Width="300" Height="60" Margin="10" Background="#E53935" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
            <Button Content="Jó szokások (Rászokás)" Click="GoodHabits_Click" Width="300" Height="60" Margin="10" Background="#43A047" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
            <Button Content="⚙️ Beállítások" Click="Settings_Click" Width="300" Height="40" Margin="10,20,10,10" Background="#757575" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Page>