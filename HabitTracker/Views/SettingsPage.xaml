<Page x:Class="HabitTracker.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="{DynamicResource CardBg}">
            <Button Content="&lt; Vissza a Főmenübe" Click="Back_Click" Width="180" Margin="15,0" Background="#E0E0E0" Foreground="{DynamicResource PrimaryText}"/>
            <TextBlock Text="Beállítások és Rendszer" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="20" HorizontalAlignment="Left">
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Width="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚙️ Általános Beállítások" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <CheckBox x:Name="NotificationsCheckBox" Content="Windows Értesítések engedélyezése" FontSize="16" Margin="0,0,0,15" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                    <TextBlock Text="Az alkalmazás a tálcán futva óránként elemzi a statisztikáidat, és Windows értesítést küld, ha egy rossz szokásnál közeleg a holtpont, vagy ha elfelejtettél egy napi jó szokást rögzíteni." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryText}" Margin="20,-5,0,20" FontSize="13"/>

                    <CheckBox x:Name="DarkModeCheckBox" Content="Sötét Mód (Alap ablak)" FontSize="16" Margin="0,0,0,15" Checked="DarkMode_Changed" Unchecked="DarkMode_Changed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>