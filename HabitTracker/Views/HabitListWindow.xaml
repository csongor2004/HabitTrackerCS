<Window x:Class="HabitTracker.Views.HabitListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szokások" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="10">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="+" Click="Add_Click" Width="40" Margin="5"/>
                <Button Content="-" Click="Delete_Click" Width="40" Margin="5"/>
            </StackPanel>
            <ListBox x:Name="HabitList" DisplayMemberPath="Name" SelectionChanged="HabitList_SelectionChanged"/>
        </DockPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="Válassz szokást!" FontSize="18" Margin="10"/>
            <Button x:Name="ActionBtn" Content="ESEMÉNY RÖGZÍTÉSE" Click="Reset_Click" Width="200" Height="50" Background="DarkRed" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>