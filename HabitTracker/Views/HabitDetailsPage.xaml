<Page x:Class="HabitTracker.Views.HabitDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#EEE">
            <Button Content="&lt; Vissza" Click="Back_Click" Width="80" Margin="10"/>
            <TextBlock Text="Szokás Részletei és Statisztikák" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <TextBlock Text="Szokás neve:"/>
                <TextBox x:Name="NameTextBox" Margin="0,5,0,15" FontSize="14"/>

                <TextBlock Text="Típus:"/>
                <ComboBox x:Name="TypeComboBox" Margin="0,5,0,25" FontSize="14">
                    <ComboBoxItem Content="Rossz szokás (Leszokás)"/>
                    <ComboBoxItem Content="Jó szokás (Rászokás)"/>
                </ComboBox>

                <Button Content="Módosítások mentése" Click="SaveHabit_Click" Height="35" Margin="0,0,0,30"/>

                <TextBlock Text="Statisztika és Predikció" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock x:Name="StatsTextBlock" TextWrapping="Wrap" FontSize="14"/>
            </StackPanel>

            <DockPanel Grid.Column="1">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="NewLogNoteTextBox" Width="250" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"/>
                    <Button Content="Új bejegyzés rögzítése" Click="AddLog_Click" Width="150" Height="30"/>
                </StackPanel>

                <Button DockPanel.Dock="Bottom" Content="Kiválasztott bejegyzés törlése" Click="DeleteLog_Click" Height="35" Margin="0,10,0,0"/>

                <ListBox x:Name="LogsList" FontSize="14">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy.MM.dd HH:mm}'}" FontWeight="Bold" Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding Note}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </Grid>
</Page>