<Page x:Class="HabitTracker.Views.HabitDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="White">
            <Button Content="&lt; Vissza" Click="Back_Click" Width="80" Margin="15,0" Background="#E0E0E0" Foreground="Black"/>
            <TextBlock Text="Kiválasztott szokás:" FontSize="18" VerticalAlignment="Center" Margin="10,0"/>
            <ComboBox x:Name="HabitSelector" Width="220" Height="35" FontSize="16" DisplayMemberPath="Name" SelectionChanged="HabitSelector_SelectionChanged" VerticalContentAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Szokás átnevezése" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBox x:Name="NameTextBox" Margin="0,0,0,20" FontSize="16" Height="35" VerticalContentAlignment="Center"/>
                        <Button Content="Módosítások mentése" Click="SaveHabit_Click" Height="40" Width="200" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Részletes Statisztika" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                            <TextBlock x:Name="StatsTextBlock" TextWrapping="Wrap" FontSize="15" LineHeight="24"/>
                        </ScrollViewer>

                        <Button Grid.Row="2" Content="Vizsgálat és Diagramok" Click="OpenAnalysis_Click" Height="45" Background="#43A047" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Eseménynapló" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="NewLogNoteTextBox" Grid.Column="0" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"/>
                        <Button Grid.Column="1" Content="Új alkalom" Click="AddLog_Click" Padding="15,0" Height="35" Background="#E53935" Margin="0,0,10,0" Foreground="White"/>
                        <Button Grid.Column="2" Content="Cheat Day" Click="AddCheatDay_Click" Padding="15,0" Height="35" Background="#FFB300" Foreground="Black"/>
                    </Grid>

                    <Button DockPanel.Dock="Bottom" Content="Kiválasztott bejegyzés törlése" Click="DeleteLog_Click" Height="35" Margin="0,15,0,0" Background="#757575"/>

                    <ListBox x:Name="LogsList" FontSize="15" BorderThickness="1" BorderBrush="#EEEEEE" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Timestamp, StringFormat=\{0:yyyy.MM.dd HH:mm\}}" FontWeight="Bold" Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding Note}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>