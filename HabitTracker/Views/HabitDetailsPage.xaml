<Page x:Class="HabitTracker.Views.HabitDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="White">
            <Button Content="&lt; Vissza" Click="Back_Click" Width="80" Margin="15,0" Background="#E0E0E0" Foreground="Black"/>
            <TextBlock Text="Szokás Kezelőpult" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Alapadatok" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Text="Név:"/>
                        <TextBox x:Name="NameTextBox" Margin="0,5,0,15" FontSize="14"/>
                        <TextBlock Text="Típus:"/>
                        <ComboBox x:Name="TypeComboBox" Margin="0,5,0,20" FontSize="14">
                            <ComboBoxItem Content="Rossz szokás (Leszokás)"/>
                            <ComboBoxItem Content="Jó szokás (Rászokás)"/>
                        </ComboBox>
                        <Button Content="Módosítások mentése" Click="SaveHabit_Click" Height="35"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Statisztika és Predikció" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock x:Name="StatsTextBlock" TextWrapping="Wrap" FontSize="14" LineHeight="20"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#DDDDDD" Opacity="0.5"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Eseménynapló" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="NewLogNoteTextBox" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14" Tag="Megjegyzés..."/>
                        <Button Content="Botlás" Click="AddLog_Click" Width="80" Height="35" Background="#E53935" Margin="0,0,10,0"/>
                        <Button Content="Cheat Day" Click="AddCheatDay_Click" Width="100" Height="35" Background="#FFB300" Foreground="Black"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Bottom" Content="Kiválasztott törlése" Click="DeleteLog_Click" Height="35" Margin="0,15,0,0" Background="#757575"/>

                    <ListBox x:Name="LogsList" FontSize="14" BorderThickness="1" BorderBrush="#EEEEEE">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy.MM.dd HH:mm}'}" FontWeight="Bold" Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding Note}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>