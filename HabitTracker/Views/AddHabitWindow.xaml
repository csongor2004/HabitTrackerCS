<Window x:Class="HabitTracker.Views.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új szokás" Height="200" Width="300" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Szokás megnevezése:" Margin="0,0,0,5"/>
        <TextBox x:Name="HabitNameInput" Margin="0,0,0,20"/>
        <Button Content="Mentés" Click="Save_Click" Height="30"/>
    </StackPanel>
</Window>
