<Window x:Class="HabitTracker.Views.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új szokás felvétele" Height="220" Width="350" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}" TextElement.Foreground="{DynamicResource PrimaryText}">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Szokás megnevezése (pl. Olvasás, Cukor):" Margin="0,0,0,10" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="HabitNameInput" Margin="0,0,0,25" Height="35" FontSize="16" VerticalContentAlignment="Center" Background="{DynamicResource CardBg}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}"/>
            <Button Content="Célkitűzés Mentése" Click="Save_Click" Height="40" Background="#2196F3" Foreground="White" FontSize="15" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>