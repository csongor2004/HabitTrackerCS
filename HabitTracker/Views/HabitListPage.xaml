<Page x:Class="HabitTracker.Views.HabitListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="{DynamicResource CardBg}">
            <Button Content="&lt; Vissza" Click="Back_Click" Width="80" Margin="10" Background="Transparent" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Foreground="{DynamicResource PrimaryText}"/>

            <TextBlock x:Name="PageTitleText" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,15,0">
                <StackPanel DockPanel.Dock="Bottom" Margin="0,15,0,0">
                    <Button Content="Új szokás hozzáadása" Click="Add_Click" Height="35" Margin="0,0,0,5" Background="#2196F3" Foreground="White"/>
                    <Button Content="Kiválasztott szokás törlése" Click="Delete_Click" Height="35" Margin="0,0,0,5" Background="#757575" Foreground="White"/>
                    <Button Content="Részletek és Statisztikák" Click="EditHabit_Click" Height="35" Background="#FFB300" Foreground="Black"/>
                </StackPanel>

                <ListBox x:Name="HabitList" SelectionChanged="HabitList_SelectionChanged" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,15" Margin="0,2" Background="{DynamicResource CardBg}" CornerRadius="4">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <StackPanel x:Name="RightPanel" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Hidden" Width="400">
                <TextBlock x:Name="SelectedHabitNameText" FontSize="36" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock x:Name="TimeLabelText" Text="Utolsó alkalom óta eltelt idő:" FontSize="15" Foreground="{DynamicResource SecondaryText}" TextAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="StatusText" FontSize="28" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Esemény oka / Megjegyzés (opcionális):" FontSize="14" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <TextBox x:Name="QuickNoteTextBox" Height="35" FontSize="14" Margin="0,0,0,15"/>

                <Button x:Name="ActionBtn" Content="ESEMÉNY RÖGZÍTÉSE" Click="Reset_Click" Height="55" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Részletek és Napló" Click="EditHabit_Click" Height="40" Background="#42A5F5" Foreground="White" FontWeight="SemiBold"/>
                    <Button Grid.Column="2" Content="Diagramok és Elemzés" Click="OpenAnalysis_Click" Height="40" Background="#43A047" Foreground="White" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>

            <TextBlock x:Name="NoSelectionText" Grid.Column="1" Text="Válassz egy szokást a listából!" FontSize="18" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>